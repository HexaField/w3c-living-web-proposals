{
  "name": "@living-web/shape-validation",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./polyfill": {
      "types": "./dist/polyfill.d.ts",
      "import": "./dist/polyfill.js",
      "require": "./dist/polyfill.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@living-web/personal-graph": "workspace:*",
    "@noble/hashes": "^2.0.1",
    "canonicalize": "^2.1.0"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
